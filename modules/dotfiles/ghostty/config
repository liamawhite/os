# Theme: Catppuccin Mocha
background = 1e1e2e
foreground = cdd6f4

# Black
palette = 0=45475a
palette = 8=585b70

# Red
palette = 1=f38ba8
palette = 9=f38ba8

# Green
palette = 2=a6e3a1
palette = 10=a6e3a1

# Yellow
palette = 3=f9e2af
palette = 11=f9e2af

# Blue
palette = 4=89b4fa
palette = 12=89b4fa

# Magenta
palette = 5=f5c2e7
palette = 13=f5c2e7

# Cyan
palette = 6=94e2d5
palette = 14=94e2d5

# White
palette = 7=bac2de
palette = 15=a6adc8

# Cursor
cursor-color = f5e0dc
cursor-text = 1e1e2e
cursor-style = block
cursor-style-blink = true

# Selection
selection-background = 414356
selection-foreground = cdd6f4

# Terminal settings
font-family = "JetBrainsMono Nerd Font"
font-size = 12
font-style = Medium
adjust-cell-width = -5%

# Window settings
window-theme = dark

# Misc settings
mouse-hide-while-typing = true
copy-on-select = true
confirm-close-surface = false

# Shell integration
shell-integration = zsh
shell-integration-features = no-cursor,sudo,title

# tmux keybinds (send escape sequences, bypassing Ghostty defaults)
keybind = cmd+w=esc:w
keybind = cmd+one=esc:1
keybind = cmd+two=esc:2
keybind = cmd+three=esc:3
keybind = cmd+four=esc:4
keybind = cmd+five=esc:5
keybind = cmd+six=esc:6
keybind = cmd+seven=esc:7
keybind = cmd+eight=esc:8
keybind = cmd+nine=esc:9
keybind = cmd+f=esc:f
keybind = cmd+t=esc:t
keybind = cmd+d=esc:d
keybind = cmd+shift+backslash=esc:|
keybind = cmd+shift+minus=esc:_
keybind = cmd+h=esc:h
keybind = cmd+j=esc:j
keybind = cmd+k=esc:k
keybind = cmd+l=esc:l
keybind = cmd+shift+h=esc:H
keybind = cmd+shift+j=esc:J
keybind = cmd+shift+k=esc:K
keybind = cmd+shift+l=esc:L
keybind = cmd+alt+h=esc:{
keybind = cmd+alt+j=esc:}
keybind = cmd+alt+k=esc:~
keybind = cmd+alt+l=esc:>
